{
	"name": "web-summary-extension",
	"private": true,
	"description": "Chrome extension: read/skip verdict + tab summaries with your Gemini API key (BYOK).",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"clean": "rm -rf dist",
		"lint": "tsc --noEmit",
		"test": "vitest",
		"test:run": "vitest run",
		"verify": "yarn lint && yarn test:run",
		"prepare": "husky",
		"notices": "node scripts/generate-third-party-notices.mjs"
	},
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"@tailwindcss/vite": "^4.1.14",
		"@types/mozilla-readability": "^0.2.1",
		"@vitejs/plugin-react": "^5.0.4",
		"lucide-react": "^0.546.0",
		"motion": "^12.23.24",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-markdown": "^10.1.0",
		"vite": "^6.2.0"
	},
	"devDependencies": {
		"@testing-library/dom": "10.4.0",
		"@testing-library/jest-dom": "6.6.3",
		"@testing-library/react": "16.3.2",
		"@types/chrome": "^0.1.40",
		"@types/node": "^22.14.0",
		"autoprefixer": "^10.4.21",
		"husky": "9.1.7",
		"jsdom": "26.1.0",
		"license-checker": "25.0.1",
		"tailwindcss": "^4.1.14",
		"typescript": "~5.8.2",
		"vitest": "3.2.4"
	}
}
